# Fii Global English — 環境変数
# これらが未設定でも "mock モード" で全機能が動作します（APIキー不要）。
# AI モードを使うときだけ設定してください。

# OpenAI（会話生成・回答評価・音声合成に使用）
OPENAI_API_KEY=

# 使用モデル（任意・未設定なら既定値）
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# クライアントに公開する既定モード: "mock" | "ai"
# 未設定なら mock。AI にしても OPENAI_API_KEY が無ければ自動で mock に落ちます。
NEXT_PUBLIC_DEFAULT_MODE=mock
